# GraphSQL MCP Server Configuration
# Copy this file to .env and update values as needed

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# SQLAlchemy database connection URL
# Examples:
#   SQLite:     sqlite:///./database.db
#   PostgreSQL: postgresql://user:password@localhost:5432/dbname
#   MySQL:      mysql+pymysql://user:password@localhost:3306/dbname
DATABASE_URL=sqlite:///./database.db

# =============================================================================
# MCP SERVER CONFIGURATION
# =============================================================================

# Server name (shown to MCP clients)
MCP_SERVER_NAME=graphsql

# Server version
MCP_SERVER_VERSION=0.1.0

# =============================================================================
# QUERY LIMITS & SECURITY
# =============================================================================

# Maximum number of rows returned per query
MAX_ROWS=1000

# Query execution timeout in seconds (0 = no timeout)
QUERY_TIMEOUT=30

# Enable read-only mode (only SELECT/SHOW/DESCRIBE allowed)
# Set to 'true' for production environments with untrusted input
READ_ONLY=false

# =============================================================================
# LOGGING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# TABLE ACCESS CONTROL (Optional)
# =============================================================================

# Whitelist of allowed tables (comma-separated, empty = allow all)
# Example: ALLOWED_TABLES=users,orders,products
ALLOWED_TABLES=

# Blacklist of denied tables (comma-separated)
# Example: DENIED_TABLES=audit_logs,system_config
DENIED_TABLES=

# =============================================================================
# AUTHENTICATION (Future Extension)
# =============================================================================

# Enable authentication
ENABLE_AUTH=false

# Authentication method: none, api_key, oauth
AUTH_METHOD=none

# API key for authentication (if AUTH_METHOD=api_key)
API_KEY=

# OAuth settings (if AUTH_METHOD=oauth)
OAUTH_ISSUER=
OAUTH_AUDIENCE=

# =============================================================================
# CONNECTION POOL SETTINGS (Advanced)
# =============================================================================

# Number of connections to maintain in pool
POOL_SIZE=5

# Maximum overflow connections above pool_size
POOL_MAX_OVERFLOW=10

# Connection timeout in seconds
POOL_TIMEOUT=30

# Recycle connections after this many seconds
POOL_RECYCLE=3600
