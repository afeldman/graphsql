# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/mydb
# Alternativ für MySQL:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/mydb
# Für SQLite:
# DATABASE_URL=sqlite:///./database.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS Origins (comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Security
API_KEY=your-secret-api-key-here
ENABLE_AUTH=false

# Pagination Defaults
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200

# Logging
LOG_LEVEL=INFO

# ===========================================
# MCP Server Configuration
# ===========================================

# MCP Server Settings
MCP_SERVER_NAME=graphsql
MCP_READ_ONLY=true
MCP_MAX_ROWS=1000
MCP_QUERY_TIMEOUT=30

# ===========================================
# SSO Configuration (for graphsql-auth proxy)
# ===========================================

# SSO Provider: azure_ad, okta, keycloak, auth0, google, github, custom
SSO_PROVIDER=azure_ad

# OAuth Client Credentials (required)
SSO_CLIENT_ID=your-client-id
SSO_CLIENT_SECRET=your-client-secret

# Azure AD specific (required for azure_ad)
SSO_TENANT_ID=your-tenant-id

# Okta / Auth0 / Keycloak specific (required for these providers)
# SSO_DOMAIN=your-domain.okta.com

# OAuth Redirect URI (must match OAuth app config)
SSO_REDIRECT_URI=http://localhost:8080/callback

# ===========================================
# Auth Proxy Configuration
# ===========================================

# Encryption key for storing user database configs (32 bytes, base64)
# Generate with: graphsql-auth --generate-key
ENCRYPTION_KEY=your-32-byte-encryption-key-here!

# User config storage settings
CONFIG_STORE_TYPE=file
CONFIG_STORE_PATH=./user_configs

# Redis URL for distributed config store (optional, for CONFIG_STORE_TYPE=redis)
# REDIS_URL=redis://localhost:6379/0

# Session settings
SESSION_TIMEOUT=3600
CLEANUP_INTERVAL=300
